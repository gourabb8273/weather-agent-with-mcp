# Use one of these for natural-language agent replies:

# Option 1: OpenAI (paid)
OPENAI_API_KEY=sk-proj-<your-api-key>

# Option 2: Ollama (free, local). Start Ollama first: ollama run mistral
USE_OLLAMA=1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=mistral:latest

# agentic = LLM calls get_weather and summarizes (can misread data). two_step = we fetch, LLM formats (accurate temps).
AGENT_MODE=two_step